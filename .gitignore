# Monorepo ignore configuration

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependency directories
node_modules/
jspm_packages/
web_modules/

# IDE & Editor files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# Frontend build & env files
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local
frontend/.env
frontend/.env.production

# Backend build & env files
backend/vendor/
backend/node_modules/
backend/public/build/
backend/public/hot/
backend/public/storage
backend/storage/*.key
backend/.phpunit.cache/
backend/.env
backend/.env.backup
backend/.env.production
backend/Homestead.json
backend/Homestead.yaml
backend/auth.json
backend/.fleet/
